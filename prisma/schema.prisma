generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id
  email              String    @unique
  emailVerified      Boolean
  name               String?
  image              String?
  activeSessionToken String?
  createdAt          DateTime
  updatedAt          DateTime

  sessions Session[]
  accounts Account[]
  profile  Profile?
  interviews Interview[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime
  updatedAt  DateTime

  @@unique([identifier, value])
}

model jwks {
  id         String   @id
  publicKey  String
  privateKey String
  createdAt  DateTime
}

model Profile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                String?
  email               String?
  avatar              String?
  targetRole          String?
  experienceLevel     String?
  primarySkills       String[]
  resumeUrl           String?
  jobDescriptionText  String?
  plan                String   @default("free")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

enum InterviewStatus {
  in_progress
  completed
  abandoned
  incomplete
  not_eligible
}

enum InterviewDifficulty {
  easy
  medium
  hard
}

model Interview {
  id                  String              @id @default(uuid())
  userId              String
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                String
  experienceLevel     String
  interviewType       String
  skills              String[]
  durationMinutes     Int
  questionTarget      String?
  timePerQuestion     String?
  sections            String[]
  questionFocus       String
  jobDescriptionText  String?
  status              InterviewStatus     @default(in_progress)
  currentDifficulty   InterviewDifficulty @default(medium)
  questionsAttempted  Int                 @default(0)
  veryPoorTotal       Int                 @default(0)
  consecutiveVeryPoor Int                 @default(0)
  score               Int?
  startedAt           DateTime            @default(now())
  completedAt         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  questions InterviewQuestion[]
  analytics InterviewAnalytics?

  @@index([userId, status])
  @@index([userId, startedAt])
}

model InterviewQuestion {
  id                String              @id @default(uuid())
  interviewId       String
  interview         Interview           @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  order             Int
  questionText      String
  difficulty        InterviewDifficulty
  answerText        String?
  answerSubmittedAt DateTime?
  answerScore       Int?
  clarityScore      Int?
  relevanceScore    Int?
  depthScore        Int?
  confidenceScore   Int?
  evaluationSummary String?
  feedback          String?
  veryPoor          Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([interviewId, order])
  @@index([interviewId])
}

model InterviewAnalytics {
  id                  String    @id @default(uuid())
  interviewId         String    @unique
  interview           Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  overallScore        Int
  clarityScore        Int
  relevanceScore      Int
  technicalDepthScore Int
  confidenceScore     Int
  strengths           String[]
  improvements        String[]
  questionFeedback    Json
  speakingPaceLabel   String?
  confidenceTrend     Int[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}
